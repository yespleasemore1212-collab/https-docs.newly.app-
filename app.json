{
  "expo": {
    "name": "Elite Connect",
    "slug": "elite-connect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/newly.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/newly.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eliteconnect.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/newly.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.eliteconnect.app"
    },
    "web": {
      "favicon": "./assets/images/newly.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      "expo-video",
      "expo-audio"
    ],
    "scheme": "eliteconnect",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
